#!/usr/bin/env bash

# SideQuest SessionStart Hook — Phase 19 Simplified
# Three concerns: DND guidance, auth status check, first-run detection
# Layer 1 context extraction: read CLAUDE.md and package.json, cache tech tags
# Uses hookSpecificOutput format (same as Superpowers plugin)

set -euo pipefail

# Validate python3 exists
command -v python3 >/dev/null 2>&1 || exit 0

# Unified config location first, then legacy
CONFIG_FILE="$HOME/.sidequest/config.json"
if [ ! -f "$CONFIG_FILE" ]; then
  CONFIG_FILE="${CLAUDE_PLUGIN_DATA:-/dev/null}/config.json"
fi

# Use python3 for JSON output — handles Unicode correctly
json_output() {
  python3 -c "
import json, sys
context = sys.stdin.read()
print(json.dumps({
  'hookSpecificOutput': {
    'hookEventName': 'SessionStart',
    'additionalContext': context
  }
}, ensure_ascii=False))
"
}

# ============================================================================
# PHASE 1: Layer 1 Context Extraction (static, cached)
# Read CLAUDE.md and package.json from current project directory
# Extract tech stack tags and cache to ~/.sidequest/tech-context.json
# ============================================================================

python3 -c "
import json
import os
import re

project_dir = os.getcwd()
tech_tags = []

# Read CLAUDE.md if present
claude_md_path = os.path.join(project_dir, 'CLAUDE.md')
if os.path.isfile(claude_md_path):
    try:
        with open(claude_md_path) as f:
            content = f.read().lower()
        # Extract tech tags from CLAUDE.md (looks for language/framework mentions)
        patterns = {
            'javascript': r'javascript|\.js',
            'typescript': r'typescript|\.ts',
            'python': r'python|\.py',
            'java': r'java\b',
            'go': r'golang|\.go',
            'rust': r'rust|cargo',
            'react': r'react|jsx',
            'nextjs': r'next\.?js',
            'vue': r'vue\.?js',
            'angular': r'angular\b',
            'svelte': r'svelte',
            'express': r'express',
            'fastify': r'fastify',
            'django': r'django',
            'flask': r'flask',
            'rails': r'rails|ruby on rails',
            'spring': r'spring\b',
            'tailwindcss': r'tailwind',
            'postgresql': r'postgres|postgresql',
            'mysql': r'mysql',
            'mongodb': r'mongo',
            'redis': r'redis\b',
            'docker': r'docker',
            'kubernetes': r'kubernetes|k8s',
            'terraform': r'terraform',
            'aws': r'aws\b|lambda|s3',
            'gcp': r'gcp|google.cloud',
            'azure': r'azure\b',
            'cloudflare': r'cloudflare|workers',
        }
        for tag, pattern in patterns.items():
            if re.search(pattern, content):
                tech_tags.append(tag)
    except:
        pass

# Read package.json if present
package_json_path = os.path.join(project_dir, 'package.json')
if os.path.isfile(package_json_path):
    try:
        with open(package_json_path) as f:
            pkg = json.load(f)
        # Extract from dependencies
        deps = {}
        for key in ['dependencies', 'devDependencies']:
            deps.update(pkg.get(key, {}))
        deps_str = ' '.join(deps.keys()).lower()

        patterns = {
            'react': r'react$',
            'nextjs': r'next$',
            'vue': r'vue$',
            'angular': r'@angular',
            'svelte': r'svelte',
            'express': r'express$',
            'fastify': r'fastify$',
            'tailwindcss': r'tailwindcss',
            'postgresql': r'pg$',
            'mysql': r'mysql2?',
            'mongodb': r'mongoose|mongodb',
            'redis': r'redis$',
            'docker': r'docker',
            'jest': r'jest$',
            'typescript': r'typescript$',
            'webpack': r'webpack$',
            'vite': r'vite$',
        }
        for tag, pattern in patterns.items():
            if re.search(pattern, deps_str):
                tech_tags.append(tag)
    except:
        pass

# Deduplicate and cache
tech_tags = list(set(tech_tags))[:15]
tech_context = {'tags': tech_tags}

# Atomic write to ~/.sidequest/tech-context.json
import tempfile
tech_file = os.path.expanduser('~/.sidequest/tech-context.json')
os.makedirs(os.path.dirname(tech_file), exist_ok=True)
temp_fd, temp_path = tempfile.mkstemp(dir=os.path.dirname(tech_file))
try:
    with os.fdopen(temp_fd, 'w') as f:
        json.dump(tech_context, f)
    os.rename(temp_path, tech_file)
except:
    try:
        os.unlink(temp_path)
    except:
        pass
" 2>/dev/null

# ============================================================================
# PHASE 1.5: Fetch remote config from S3 (500ms timeout, cache fallback)
# ============================================================================

REMOTE_CONFIG_URL="https://get.trysidequest.ai/config.json"
REMOTE_CONFIG_CACHE="$HOME/.sidequest/remote-config.json"

python3 -c "
import json, os, sys, tempfile
try:
    import urllib.request
    req = urllib.request.Request(sys.argv[1])
    with urllib.request.urlopen(req, timeout=0.5) as resp:
        data = resp.read().decode()
    # Validate JSON
    parsed = json.loads(data)
    # Atomic write to cache
    cache_path = sys.argv[2]
    os.makedirs(os.path.dirname(cache_path), exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=os.path.dirname(cache_path))
    try:
        with os.fdopen(fd, 'w') as f:
            json.dump(parsed, f)
        os.rename(tmp, cache_path)
    except:
        try: os.unlink(tmp)
        except: pass
except:
    pass  # Silently fall back to cached version
" "$REMOTE_CONFIG_URL" "$REMOTE_CONFIG_CACHE" 2>/dev/null

# ============================================================================
# PHASE 2: Check auth status and emit guidance
# ============================================================================

if [ -f "$CONFIG_FILE" ]; then
  TOKEN=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('token',''))" "$CONFIG_FILE" 2>/dev/null || echo "")
  if [ -n "$TOKEN" ]; then
    # Logged in — emit three concerns: DND guidance, first-run detection

    # First-run detection: check if timing-state.json exists
    FIRST_RUN_GUIDANCE=""
    TIMING_FILE="$HOME/.sidequest/timing-state.json"
    if [ ! -f "$TIMING_FILE" ]; then
      FIRST_RUN_GUIDANCE="Run /sidequest:status to see pipeline health and schedule your first quest."
    fi

    cat <<CONTEXT | json_output
SideQuest is enabled and authenticated.

**DND Guidance:** If you feel overwhelmed by quests, don't disable the plugin. Instead, use /sidequest:dnd to temporarily pause quests. You control the schedule.

$FIRST_RUN_GUIDANCE
CONTEXT
    exit 0
  fi
fi

# ============================================================================
# PHASE 3: Not logged in — nudge to authenticate
# ============================================================================

GUIDANCE="SideQuest plugin installed but not authenticated. Run /sidequest:login to authenticate."

echo "$GUIDANCE" | json_output
exit 0
